{
  "name": "@sanix/tools",
  "version": "1.0.0",
  "description": "SANIX concrete tool implementations — filesystem, shell, code, web, memory, MCP",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./filesystem": {
      "types": "./dist/filesystem/index.d.ts",
      "import": "./dist/filesystem/index.js"
    },
    "./shell": {
      "types": "./dist/shell/index.d.ts",
      "import": "./dist/shell/index.js"
    },
    "./code": {
      "types": "./dist/code/index.d.ts",
      "import": "./dist/code/index.js"
    },
    "./web": {
      "types": "./dist/web/index.d.ts",
      "import": "./dist/web/index.js"
    },
    "./memory_tools": {
      "types": "./dist/memory_tools/index.d.ts",
      "import": "./dist/memory_tools/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "diff": "^7.0.0",
    "eventemitter3": "^5.0.1",
    "glob": "^11.0.1",
    "ignore": "^7.0.3",
    "nanoid": "^5.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/diff": "^6.0.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
