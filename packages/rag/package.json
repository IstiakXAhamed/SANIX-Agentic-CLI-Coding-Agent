{
  "name": "@sanix/rag",
  "version": "1.0.0",
  "description": "SANIX RAG 2.0 — document store with chunking, hybrid retrieval (vector + BM25 + keyword with z-score fusion), LLM reranking (cross-encoder / LLM / mono-t5), query rewriting (expand/decompose/HyDE/step-back/rephrase/multilingual), multi-hop retrieval, end-to-end RAG pipeline with citation extraction.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@sanix/core": "*",
    "@sanix/optimizer": "*",
    "@sanix/memory-v2": "*",
    "@sanix/providers": "*",
    "better-sqlite3": "^11.10.0",
    "zod": "^3.24.0",
    "nanoid": "^5.1.0",
    "eventemitter3": "^5.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
