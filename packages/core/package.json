{
  "name": "@sanix/core",
  "version": "1.0.0",
  "description": "SANIX orchestration engine — OODA agent loop, hierarchical memory, token-budget context, and tool registry",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./agent": {
      "types": "./dist/agent/index.d.ts",
      "import": "./dist/agent/index.js"
    },
    "./memory": {
      "types": "./dist/memory/index.d.ts",
      "import": "./dist/memory/index.js"
    },
    "./context": {
      "types": "./dist/context/index.d.ts",
      "import": "./dist/context/index.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "import": "./dist/tools/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@sanix/config": "*",
    "@sanix/providers": "*",
    "@sanix/memory-v2": "*",
    "@sanix/optimizer": "*",
    "@sanix/compressor": "*",
    "better-sqlite3": "^11.10.0",
    "@xenova/transformers": "^2.17.2",
    "@lancedb/lancedb": "^0.30.0",
    "eventemitter3": "^5.0.1",
    "zod": "^3.24.0",
    "nanoid": "^5.1.0",
    "p-limit": "^6.2.0",
    "p-retry": "^6.2.1",
    "diff": "^7.0.0",
    "glob": "^11.0.1",
    "ignore": "^7.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^6.0.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
