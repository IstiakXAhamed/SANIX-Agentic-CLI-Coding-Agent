{
  "name": "@sanix/bench",
  "version": "1.0.0",
  "description": "SANIX benchmarks — a suite of reasoning / coding / tools / memory / context / multi-turn benchmarks, a runner that uses the AgentLoop or direct provider calls, and reporters (ASCII / JSON / Markdown) for PR-ready output.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./benchmarks": {
      "types": "./dist/benchmarks/index.d.ts",
      "import": "./dist/benchmarks/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@sanix/core": "*",
    "@sanix/providers": "*",
    "zod": "^3.24.0",
    "nanoid": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
