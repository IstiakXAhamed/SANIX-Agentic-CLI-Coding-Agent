{
  "name": "@sanix/prbot",
  "version": "1.0.0",
  "description": "SANIX PR review bot — 4 platform clients (GitHub/GitLab/Bitbucket/Gitea), ReviewEngine with 52 rules, CommentFormatter, and a webhook handler. Pluggable per-platform, configurable per-repo.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./platforms": {
      "types": "./dist/platforms/index.d.ts",
      "import": "./dist/platforms/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "nanoid": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
