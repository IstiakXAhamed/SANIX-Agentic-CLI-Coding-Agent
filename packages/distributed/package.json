{
  "name": "@sanix/distributed",
  "version": "1.0.0",
  "description": "SANIX distributed mode — multi-machine agent clusters via the REST API. Service discovery (static/DNS/Consul/K8s/etcd), node registry, task dispatcher with 4 load-balancing strategies, cluster coordinator, worker node, cluster REST endpoints, drop-in distributed SubAgentManager and AgentTeam replacements.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./discovery": {
      "types": "./dist/discovery/index.d.ts",
      "import": "./dist/discovery/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@sanix/core": "*",
    "@sanix/providers": "*",
    "@sanix/server": "*",
    "@sanix/multiagent": "*",
    "zod": "^3.24.0",
    "nanoid": "^5.1.0",
    "eventemitter3": "^5.0.1",
    "p-limit": "^6.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
