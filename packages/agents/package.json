{
  "name": "@sanix/agents",
  "version": "1.0.0",
  "description": "SANIX specialized agents — Security Sentinel, Migration Maestro, Test Architect, Perf Profiler, Doc Doctor. Built on @sanix/core, @sanix/tools, @sanix/sandbox with a unified SpecializedAgent contract.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@sanix/core": "^1.0.0",
    "@sanix/providers": "^1.0.0",
    "@sanix/tools": "^1.0.0",
    "@sanix/intel": "^1.0.0",
    "@sanix/sandbox": "^1.0.0",
    "zod": "^3.24.0",
    "nanoid": "^5.1.0",
    "eventemitter3": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
