{
  "name": "@sanix/docai",
  "version": "1.0.0",
  "description": "SANIX document AI — PDF/DOCX/PPTX/XLSX/HTML/Image processing with OCR, extraction, and summarization",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "nanoid": "^5.1.0",
    "zod": "^3.24.0",
    "mime-types": "^2.1.35"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/mime-types": "^2.1.4",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  },
  "engines": { "node": ">=20.0.0" },
  "license": "MIT"
}
