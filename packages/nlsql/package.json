{
  "name": "@sanix/nlsql",
  "version": "1.0.0",
  "description": "SANIX natural-language-to-SQL — schema extraction & summarization, NL→SQL generation, validation, execution, and chart suggestions",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "nanoid": "^5.1.0",
    "zod": "^3.24.0",
    "eventemitter3": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  },
  "engines": { "node": ">=20.0.0" },
  "license": "MIT"
}
